<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Project Title | Paper Page</title>
    <meta
      name="description"
      content="Project page for an academic paper: abstract, video, method, qualitative results, and citation."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="src/styles.css" />
  </head>
  <body>
    <header class="hero">
      <div class="hero__grain"></div>
      <div class="container hero__content">
        <p class="eyebrow">Conference 2026</p>
        <h1 class="title">IntentReact : Guiding Reactive Object-Centric Navigation via Topological Intent</h1>
        <p class="authors">
          Author A<sup>1*</sup>, Author B<sup>1*</sup>, Author C<sup>2</sup>, Author D<sup>1</sup>
        </p>
        <p class="affiliations">
          <sup>1</sup>University / Lab Name &nbsp; <sup>2</sup>Institute Name
          <br />
          <span>* Equal contribution</span>
        </p>

        <div class="cta-row">
          <a class="btn" href="#" target="_blank" rel="noreferrer">Paper (PDF)</a>
          <a class="btn" href="#" target="_blank" rel="noreferrer">Code</a>
          <a class="btn" href="#" target="_blank" rel="noreferrer">Dataset</a>
          <a class="btn" href="#video">Video</a>
        </div>
      </div>
    </header>

    <main>
      <section class="section container teaser">
        <h2>Teaser</h2>
        <img src="img/teaser.png" alt="Teaser image showing the core method result" />
        <p class="caption">Replace with your strongest visual result.</p>
      </section>

      <section class="section container">
        <h2>Abstract</h2>
        <p class="text-block">
          Write a concise abstract (5-8 sentences). Explain the task, core idea, and headline
          results. Keep this section readable and direct.
        </p>
      </section>

      <section id="video" class="section container">
        <h2>Video</h2>
        <div class="video-grid">
          <article class="card">
            <h3>Local MP4 Demo</h3>
            <video controls preload="metadata" playsinline>
              <source src="video/demo.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </article>
          <article class="card">
            <h3>YouTube Embed (Optional)</h3>
            <div class="embed-wrap">
              <iframe
                src="https://www.youtube.com/embed/dQw4w9WgXcQ"
                title="Project video"
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              ></iframe>
            </div>
          </article>
        </div>
      </section>

      <section class="section container">
        <h2>Method Overview</h2>
        <img src="img/method.png" alt="Method pipeline diagram" />
        <p class="caption">Use Figure 2 or your architecture pipeline figure.</p>
      </section>

      <section class="section container">
        <h2>Qualitative Results</h2>
        <div class="result-grid">
          <figure class="result-card">
            <img src="img/result_01.png" alt="Result example 1" />
            <figcaption>Scene 1</figcaption>
          </figure>
          <figure class="result-card">
            <img src="img/result_02.png" alt="Result example 2" />
            <figcaption>Scene 2</figcaption>
          </figure>
          <figure class="result-card">
            <img src="img/result_03.png" alt="Result example 3" />
            <figcaption>Scene 3</figcaption>
          </figure>
        </div>
      </section>

      <section class="section container citation">
        <h2>Citation</h2>
        <pre id="bibtex">@inproceedings{yourproject2026,
  title={Your Paper Title},
  author={Author, A and Author, B and Author, C},
  booktitle={Conference Name},
  year={2026}
}</pre>
        <button id="copyBibBtn" class="btn btn--small" type="button">Copy BibTeX</button>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        <p>
          This page template is inspired by popular computer vision project pages.
          Customize freely for your research project.
        </p>
      </div>
    </footer>

    <script src="src/main.js"></script>
  </body>
</html>
